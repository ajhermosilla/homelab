# VPS Environment Variables
# Vultr - Helper Node
# Copy to .env and customize

# =============================================================================
# GENERAL
# =============================================================================

# Timezone
TZ=America/Asuncion

# VPS Public IP (get from Vultr dashboard)
VPS_IP=YOUR_VPS_PUBLIC_IP

# =============================================================================
# PI-HOLE
# =============================================================================

# Web interface password (CHANGE THIS!)
PIHOLE_PASSWORD=changeme

# =============================================================================
# DERP
# =============================================================================

# DERP domain (point DNS to this VPS)
DERP_DOMAIN=derp.cronova.dev

# =============================================================================
# TAILSCALE
# =============================================================================

# Tailscale auth key (from Headscale)
# Generate: headscale preauthkeys create --user augusto --reusable
TAILSCALE_AUTHKEY=

# Headscale server URL
HEADSCALE_URL=https://hs.cronova.dev

# =============================================================================
# TAILSCALE IPS (Reference)
# =============================================================================
#
# VPS will get: 100.64.0.20
#
# Can access homelab services via Tailscale:
#   - Vaultwarden: 100.68.63.168:8843
#   - Home Assistant: 100.68.63.168:8123
#   - Pi-hole (home): 100.68.63.168:53
#   - Start9: 100.64.0.11
#   - NAS: 100.82.77.97
#
# =============================================================================

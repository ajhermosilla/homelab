# Headscale Configuration
# VPS - Vultr (24/7 Operation)
# https://headscale.net/ref/configuration/

# =============================================================================
# Server Configuration
# =============================================================================

# Public URL for clients to connect
server_url: https://hs.cronova.dev

# Listen addresses (Caddy handles TLS on 443, Headscale listens on 8080)
listen_addr: 0.0.0.0:8080

# Metrics (for Prometheus/Grafana)
metrics_listen_addr: 127.0.0.1:9090

# =============================================================================
# Noise Protocol Keys
# =============================================================================

# Private key for Noise protocol (auto-generated if not exists)
noise:
  private_key_path: /var/lib/headscale/noise_private.key

# =============================================================================
# Database
# =============================================================================

database:
  type: sqlite
  sqlite:
    path: /var/lib/headscale/db.sqlite

# =============================================================================
# DERP (Relay Servers)
# =============================================================================

derp:
  server:
    # Enable embedded DERP server on VPS
    enabled: true
    region_id: 999
    region_code: "cronova"
    region_name: "Cronova VPS"
    stun_listen_addr: 0.0.0.0:3478
    private_key_path: /var/lib/headscale/derp_server_private.key

  # Use Tailscale's public DERP servers as fallback
  urls:
    - https://controlplane.tailscale.com/derpmap/default

  # Auto-update DERP map
  auto_update_enabled: true
  update_frequency: 24h

# =============================================================================
# DNS Configuration
# =============================================================================

dns:
  # Enable MagicDNS
  magic_dns: true

  # Base domain for MagicDNS (must NOT overlap with server_url domain)
  # Devices accessible as hostname.hs.net internally
  base_domain: hs.net

  # Nameservers for Tailscale clients
  nameservers:
    global:
      - 1.1.1.1      # Cloudflare (public fallback)
      - 9.9.9.9      # Quad9 (public fallback)
    split:
      cronova.dev:
        - 100.100.100.100  # MagicDNS (serves extra_records)

  # Extra DNS records (optional)
  extra_records:
    - name: "nas"
      type: "A"
      value: "100.82.77.97"
    - name: "oga"
      type: "A"
      value: "100.78.12.241"

# =============================================================================
# IP Allocation
# =============================================================================

prefixes:
  v4: 100.64.0.0/10         # IPv4 (Tailscale default range)
  v6: fd7a:115c:a1e0::/48   # IPv6 (optional)
  allocation: random

# =============================================================================
# Node Settings
# =============================================================================

# Ephemeral nodes timeout (0 = never expire)
ephemeral_node_inactivity_timeout: 30m

# Allow routes to be advertised by nodes
# (e.g., for exit nodes or subnet routing)

# =============================================================================
# Security
# =============================================================================

# Disable anonymous telemetry
disable_check_updates: false

# =============================================================================
# Logging
# =============================================================================

log:
  level: info
  format: text

# =============================================================================
# TLS Configuration
# =============================================================================

# TLS is handled by Caddy reverse proxy (recommended)
# Headscale listens on HTTP port 8080, Caddy terminates TLS on 443
#
# If running Headscale standalone without Caddy, uncomment:
# tls_letsencrypt_hostname: hs.cronova.dev
# tls_letsencrypt_cache_dir: /var/lib/headscale/cache
# tls_letsencrypt_challenge_type: HTTP-01

# =============================================================================
# Access Control (ACLs) - Optional
# =============================================================================

# ACL policy file for fine-grained access control
# Uses HuJSON format (JSON with comments)
# See acl.json.example for template
policy:
  path: /etc/headscale/acl.json

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file:
#    cp config.yaml.example config.yaml
#
# 2. Update server_url to your domain
#
# 3. Ensure DNS A record points to VPS IP:
#    hs.cronova.dev -> VPS_IP (Cloudflare proxy OFF)
#
# 4. Start Headscale:
#    docker compose up -d
#
# 5. Create user:
#    docker exec headscale headscale users create augusto
#
# 6. Generate auth key:
#    docker exec headscale headscale preauthkeys create \
#      --user augusto --reusable --expiration 720h
#
# 7. Connect devices:
#    tailscale up --login-server=https://hs.cronova.dev --authkey=<key>
#
# =============================================================================
# IP ALLOCATION PLAN
# =============================================================================
#
# | Range          | Purpose              |
# |----------------|----------------------|
# | 100.64.0.1-9   | Mobile Kit           |
# | 100.64.0.10-49 | Fixed Homelab        |
# | 100.64.0.50-99 | Reserved             |
# | 100.64.0.100+  | VPS/Cloud            |
#
# =============================================================================

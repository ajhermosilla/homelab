{
  // Headscale ACL Policy
  // https://headscale.net/ref/acls/
  // Copy to acl.json and customize

  // Named hosts (optional aliases)
  "hosts": {
    "vps": "100.77.172.46",
    "macbook": "100.86.220.9",
    "phone": "100.110.253.126"
  },

  // ACL rules - who can access what
  "acls": [
    // Allow all devices to reach all other devices
    {
      "action": "accept",
      "src": ["*"],
      "dst": ["*:*"]
    }
  ]

  // Example: Restrictive rules (uncomment to use)
  // "acls": [
  //   // Allow macbook to reach everything
  //   {
  //     "action": "accept",
  //     "src": ["macbook"],
  //     "dst": ["*:*"]
  //   },
  //   // Allow phone to reach only vps (exit node)
  //   {
  //     "action": "accept",
  //     "src": ["phone"],
  //     "dst": ["vps:*"]
  //   }
  // ]
}

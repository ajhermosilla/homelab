# Restic REST Server htpasswd file
# =================================
#
# This file authenticates clients connecting to Restic REST server.
#
# SETUP:
# 1. Copy this file to 'htpasswd' (remove .example)
# 2. Generate password hash:
#    htpasswd -B -c htpasswd augusto
#
# FORMAT:
# username:bcrypt-hashed-password
#
# EXAMPLE (DO NOT USE - generate your own):
# augusto:$2y$05$example.hash.here
#
# GENERATE WITH:
# htpasswd -B htpasswd <username>
#
# Or with Docker:
# docker run --rm httpd:alpine htpasswd -nbB augusto "password"

# Common Environment Variables
# Shared across all homelab services
#
# Usage in docker-compose.yml:
#   env_file:
#     - ../../shared/common.env  # adjust path as needed
#     - .env                     # service-specific secrets

# Timezone (Paraguay)
TZ=America/Asuncion

# User/Group IDs for LinuxServer.io images
# Match host user for correct file permissions
PUID=1000
PGID=1000

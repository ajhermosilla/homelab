# Mobile Kit Environment Variables
# RPi 5 - Headscale + Pi-hole
# Copy to .env and customize

# =============================================================================
# GENERAL
# =============================================================================

# Timezone (Paraguay)
TZ=America/Asuncion

# Host IP address (RPi 5 on local network)
# Update this to match your Beryl AX DHCP reservation
HOST_IP=192.168.8.10

# =============================================================================
# PI-HOLE
# =============================================================================

# Web interface password (CHANGE THIS!)
PIHOLE_PASSWORD=changeme

# Upstream DNS servers (semicolon separated)
# Options:
#   - Cloudflare: 1.1.1.1;1.0.0.1
#   - Quad9: 9.9.9.9;149.112.112.112
#   - Google: 8.8.8.8;8.8.4.4
UPSTREAM_DNS=1.1.1.1;9.9.9.9

# =============================================================================
# HEADSCALE
# =============================================================================

# Domain for Headscale (update DNS to point to this host)
HEADSCALE_DOMAIN=hs.cronova.dev

# ACME email for Let's Encrypt certificates
ACME_EMAIL=augusto@cronova.dev

# =============================================================================
# TAILSCALE IPs (Reference)
# =============================================================================
#
# These are the Tailscale IPs assigned to each device:
#
# Mobile Kit:
#   RPi 5:    100.64.0.1
#   MacBook:  100.64.0.2
#
# Fixed Homelab:
#   Docker VM: 100.64.0.10
#   RPi 4:     100.64.0.11
#   NAS:       100.64.0.12
#
# VPS:
#   Vultr:     100.64.0.20
#
# =============================================================================

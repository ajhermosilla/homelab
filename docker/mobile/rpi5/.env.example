# Mobile Kit Environment Variables
# RPi 5 - Headscale + Pi-hole
# Copy to .env and customize

# =============================================================================
# GENERAL
# =============================================================================

# Timezone (Paraguay)
TZ=America/Asuncion

# Host IP address (RPi 5 on local network)
# Must match Beryl AX DHCP reservation for RPi 5
HOST_IP=192.168.8.5

# =============================================================================
# PI-HOLE
# =============================================================================

# Web interface password (CHANGE THIS!)
PIHOLE_PASSWORD=changeme

# Upstream DNS servers (semicolon separated)
# Options:
#   - Cloudflare: 1.1.1.1;1.0.0.1
#   - Quad9: 9.9.9.9;149.112.112.112
#   - Google: 8.8.8.8;8.8.4.4
UPSTREAM_DNS=1.1.1.1;9.9.9.9

# =============================================================================
# HEADSCALE
# =============================================================================

# Domain for Headscale (update DNS to point to this host)
HEADSCALE_DOMAIN=hs.cronova.dev

# ACME email for Let's Encrypt certificates
ACME_EMAIL=augusto@cronova.dev

# =============================================================================
# BACKUPS
# =============================================================================

# Path for Headscale hourly backups
# Mount your NAS here: /mnt/nas/backups/headscale
BACKUP_PATH=/mnt/nas/backups/headscale

# Backup retention in hours (720 = 30 days)
BACKUP_RETENTION_HOURS=720

# =============================================================================
# TAILSCALE IPs (Reference - actual assigned IPs)
# =============================================================================
#
# Mobile Kit:
#   RPi 5:    100.64.0.1
#   MacBook:  100.86.220.9
#
# Fixed Homelab:
#   Proxmox:   100.78.12.241
#   OPNsense:  100.79.230.235
#   Docker VM: 100.68.63.168
#   NAS:       100.64.0.12 (planned)
#
# VPS:

# Headscale Configuration
# Mobile Kit - RPi 5
# https://headscale.net/ref/configuration/

# =============================================================================
# Server Configuration
# =============================================================================

# Public URL for clients to connect
# Update this to your domain
server_url: https://hs.cronova.dev

# Listen addresses
listen_addr: 0.0.0.0:443

# Metrics (optional, for monitoring)
metrics_listen_addr: 127.0.0.1:9090

# =============================================================================
# Database
# =============================================================================

database:
  type: sqlite
  sqlite:
    path: /var/lib/headscale/db.sqlite

# =============================================================================
# DERP (Relay Servers)
# =============================================================================

derp:
  server:
    # Enable embedded DERP server
    enabled: true
    region_id: 999
    region_code: "cronova"
    region_name: "Cronova Mobile"
    stun_listen_addr: 0.0.0.0:3478

  # Use Tailscale's public DERP servers as fallback
  urls:
    - https://controlplane.tailscale.com/derpmap/default

  # Auto-update DERP map
  auto_update_enabled: true
  update_frequency: 24h

# =============================================================================
# DNS Configuration
# =============================================================================

dns_config:
  # Enable MagicDNS
  magic_dns: true

  # Base domain for MagicDNS
  base_domain: cronova.dev

  # Nameservers for clients (Pi-hole on same RPi 5)
  nameservers:
    - 100.64.0.1  # RPi 5 Pi-hole (Tailscale IP)

  # Override local DNS for specific domains (optional)
  # extra_records:
  #   - name: "nas.cronova.dev"
  #     type: "A"
  #     value: "100.64.0.12"

# =============================================================================
# IP Allocation
# =============================================================================

ip_prefixes:
  - 100.64.0.0/10  # IPv4 (Tailscale default range)
  - fd7a:115c:a1e0::/48  # IPv6 (optional)

# =============================================================================
# Security
# =============================================================================

# Disable anonymous metrics
disable_check_updates: false

# Node expiry (0 = never)
ephemeral_node_inactivity_timeout: 30m

# =============================================================================
# Logging
# =============================================================================

log:
  level: info
  format: text

# =============================================================================
# TLS Configuration
# =============================================================================

# For production with real domain, use Let's Encrypt
# For local/development, can use self-signed
tls_cert_path: ""
tls_key_path: ""

# Let Headscale manage TLS via ACME (recommended)
acme_url: https://acme-v02.api.letsencrypt.org/directory
acme_email: augusto@cronova.dev

# =============================================================================
# Access Control (ACLs)
# =============================================================================

# ACL policy file (optional)
# policy:
#   path: /etc/headscale/acl.yaml

# =============================================================================
# OIDC (Optional - for web-based login)
# =============================================================================

# oidc:
#   issuer: ""
#   client_id: ""
#   client_secret: ""

# Coolify PaaS - Environment Variables
# Fixed Homelab - NAS
#
# These variables are used by the backup sidecar (docker-compose.backup.yml).
# Coolify's own .env lives at /data/coolify/source/.env (managed by Coolify).

# --- Restic Backup ---
RESTIC_USER=augusto
RESTIC_PASS=<htpasswd-password-for-restic-rest>
RESTIC_PASSWORD=<restic-encryption-key>

# Homelab repo root (used for mounting shared backup scripts)
HOMELAB_ROOT=/opt/homelab/repo

# --- Coolify Configuration Reference ---
# These are set in /data/coolify/source/.env, NOT here.
# Documented for reference only.
#
# APP_ID=<openssl rand -hex 16>
# APP_KEY=base64:<openssl rand -base64 32>
# APP_PORT=8888
# DB_PASSWORD=<openssl rand -base64 32>
# REDIS_PASSWORD=<openssl rand -base64 32>
# PUSHER_APP_ID=<openssl rand -hex 8>
# PUSHER_APP_KEY=<openssl rand -hex 16>
# PUSHER_APP_SECRET=<openssl rand -hex 16>
#
# --- Admin Account ---
# ROOT_USERNAME=augusto
# ROOT_USER_EMAIL=augusto@cronova.dev
#
# --- Cloudflare DNS-01 (for Traefik TLS) ---
# CF_DNS_API_TOKEN=<cloudflare-api-token>

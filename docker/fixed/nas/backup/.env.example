# NAS Backup Stack Environment Variables
# Copy to .env and customize

# Restic REST server data directory
# This is where restic repositories are stored
BACKUP_DATA=/srv/backup/restic

# htpasswd file for authentication
# Create with: htpasswd -B -c htpasswd augusto
# The htpasswd file must exist in this directory before starting

# Offsite sync (rclone to Google Drive)
VPS_HOST=100.77.172.46
VPS_USER=linuxuser
VPS_BACKUP_PATH=/opt/homelab/headscale/backups
RCLONE_REMOTE=gdrive-crypt:homelab
RCLONE_BWLIMIT=5M
NTFY_URL=https://notify.cronova.dev
OFFSITE_SSH_KEY=/root/.ssh/offsite-key

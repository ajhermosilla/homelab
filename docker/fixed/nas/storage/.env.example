# NAS Storage Stack Environment Variables
# Copy to .env and customize

# Timezone
TZ=America/Asuncion

# User/Group IDs (match your NAS user)
PUID=1000
PGID=1000

# Samba configuration
SAMBA_USER=augusto
SAMBA_PASSWORD=your-secure-samba-password

# Volume paths (symlinks in /srv point to actual drives)
MEDIA_PATH=/srv/media
DATA_PATH=/srv/data
DOWNLOADS_PATH=/srv/downloads
BACKUP_PATH=/srv/backup
SYNC_PATH=/srv/sync

# Automation Stack Environment Variables
# Copy to .env and customize

# =============================================================================
# GENERAL
# =============================================================================

# Timezone
TZ=America/Asuncion

# Path to homelab repo (required for backup script mount)
# Default: /opt/homelab/repo
HOMELAB_ROOT=/home/augusto/homelab

# MQTT credentials (create after first start)
# docker exec -it mosquitto mosquitto_passwd -c /mosquitto/config/password.txt homeassistant
# MQTT_USER=homeassistant
# MQTT_PASS=your-password

# =============================================================================
# BACKUP SIDECAR (Home Assistant)
# =============================================================================
# NOTE: Use the SAME Restic password as security stack for shared repository

# Restic REST server credentials (NAS at 192.168.0.12:8000)
RESTIC_USER=augusto
RESTIC_PASS=your-htpasswd-password

# Restic encryption password (MUST match security stack!)
# Generate once: openssl rand -base64 32
# Use same value in: security/.env and automation/.env
RESTIC_PASSWORD=your-restic-encryption-password

# Optional: Override repository URL
# RESTIC_REPOSITORY=rest:http://augusto:pass@192.168.0.12:8000/homeassistant

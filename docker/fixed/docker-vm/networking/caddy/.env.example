# Caddy Environment Variables
# Copy to .env and customize

# Timezone
TZ=America/Asuncion

# Cloudflare API Token for DNS-01 challenge (Let's Encrypt)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone / DNS / Edit + Zone / Zone / Read
# Zone: cronova.dev only
CLOUDFLARE_API_TOKEN=your-scoped-api-token-here

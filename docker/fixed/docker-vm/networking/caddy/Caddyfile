# =============================================================================
# Fixed Homelab Caddyfile
# Location: docker/fixed/docker-vm/networking/caddy/Caddyfile
# =============================================================================
#
# Internal reverse proxy for services on Docker VM.
# Accessed via LAN (192.168.0.10) or Tailscale (100.68.63.168).
#
# TLS: Let's Encrypt certificates via Cloudflare DNS-01 challenge.
# No ports need to be open to the internet.
# See docs/certificate-strategy.md for details.
#
# Services are proxied from host.docker.internal (Docker VM localhost).

# Global options
{
	email augusto@cronova.dev
}

# =============================================================================
# SNIPPETS
# =============================================================================

(internal_tls) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

(access_log) {
	log {
		output file /data/logs/{args[0]}.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}

# Authelia forward_auth snippet
# Import this in any service block to require SSO authentication.
# Do NOT use on services with their own auth (HA, Frigate, Vaultwarden, Immich).
(authelia) {
	forward_auth authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

# =============================================================================
# AUTH
# =============================================================================

# Authelia - SSO Portal (Oke)
# Access: https://auth.cronova.dev
auth.cronova.dev {
	import internal_tls
	import security_headers
	reverse_proxy authelia:9091
}

# =============================================================================
# INTERNAL SERVICES
# =============================================================================

# Vaultwarden - Password Manager
# Access: https://vault.cronova.dev (internal only, via Tailscale/LAN)
# Own auth — no Authelia
vault.cronova.dev {
	import internal_tls
	import security_headers
	reverse_proxy vaultwarden:80
}

# Home Assistant - Automation (Jara)
# Access: https://jara.cronova.dev
# Own auth — no Authelia
jara.cronova.dev {
	import internal_tls
	import security_headers
	reverse_proxy host.docker.internal:8123
}

# Jellyfin - Media Server (Yrasema)
# Access: https://yrasema.cronova.dev
# Own auth — no Authelia (clients can't handle forward auth/TOTP)
yrasema.cronova.dev {
	import internal_tls
	import security_headers
	reverse_proxy host.docker.internal:8096
}

# Frigate - NVR (Taguato)
# Access: https://taguato.cronova.dev
# Own auth — no Authelia
taguato.cronova.dev {
	import internal_tls
	import security_headers
	import access_log taguato
	reverse_proxy https://frigate:8971 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

# Forgejo - Git Server (NAS)
# Access: https://git.cronova.dev
git.cronova.dev {
	import internal_tls
	import security_headers
	reverse_proxy 192.168.0.12:3000
}

# Immich - Photos (Vera)
# Access: https://vera.cronova.dev
# Own auth — no Authelia
vera.cronova.dev {
	import internal_tls
	import security_headers
	reverse_proxy immich-server:2283
}


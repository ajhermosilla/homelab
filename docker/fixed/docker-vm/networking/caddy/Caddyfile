# =============================================================================
# Fixed Homelab Caddyfile
# Location: docker/fixed/docker-vm/networking/caddy/Caddyfile
# =============================================================================
#
# Internal reverse proxy for services on Docker VM.
# Accessed via Tailscale mesh (100.68.63.168) or local network (192.168.0.10).
#
# TLS: Not used for internal services — Tailscale WireGuard tunnel provides
# end-to-end encryption. `tailscale cert` is not available with Headscale.
# See docs/certificate-strategy.md for details.
#
# Services are proxied from host.docker.internal (Docker VM localhost).

# Global options
{
	email augusto@cronova.dev
	auto_https off
}

# =============================================================================
# INTERNAL SERVICES
# =============================================================================

# Vaultwarden - Password Manager
# Access: http://192.168.0.10:8843 or via VPS proxy (vault.cronova.dev)
:8843 {
	reverse_proxy host.docker.internal:8843
}

# Home Assistant - Automation
# Access: http://home.cronova.dev or http://192.168.0.10:8123
http://home.cronova.dev {
	reverse_proxy host.docker.internal:8123
}

# Jellyfin - Media Server
# Access: http://media.cronova.dev or http://192.168.0.10:8096
http://media.cronova.dev {
	reverse_proxy host.docker.internal:8096
}

# Frigate - NVR
# Access: http://frigate.cronova.dev or http://192.168.0.10:5000
http://frigate.cronova.dev {
	reverse_proxy host.docker.internal:5000

	# WebSocket support for live view
	@websockets {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websockets host.docker.internal:5000
}

# =============================================================================
# ARR STACK
# =============================================================================

# Sonarr
http://sonarr.cronova.dev {
	reverse_proxy host.docker.internal:8989
}

# Radarr
http://radarr.cronova.dev {
	reverse_proxy host.docker.internal:7878
}

# Prowlarr
http://prowlarr.cronova.dev {
	reverse_proxy host.docker.internal:9696
}

# =============================================================================
# NOTES
# =============================================================================
#
# DNS Configuration:
#   For *.cronova.dev subdomains to resolve to Docker VM:
#   - Add Pi-hole local DNS entries, OR
#   - Add Cloudflare DNS pointing to Tailscale IP (100.68.63.168)
#
# Direct Access (no reverse proxy needed):
#   - Pi-hole: http://192.168.0.10:80/admin
#   - Home Assistant: http://192.168.0.10:8123
#   - Jellyfin: http://192.168.0.10:8096
#   - Frigate: http://192.168.0.10:5000
#
# Docker Network:
#   Caddy uses host.docker.internal to reach services on Docker VM.
#   Requires: extra_hosts: ["host.docker.internal:host-gateway"]
#
# =============================================================================

# =============================================================================
# Fixed Homelab Caddyfile
# Location: docker/fixed/docker-vm/networking/caddy/Caddyfile
# =============================================================================
#
# Internal reverse proxy for services on Docker VM.
# Accessed via Tailscale mesh (100.64.0.10) or local network (192.168.1.10).
#
# Services are proxied from host.docker.internal (Docker VM localhost).

# Global options
{
    # Email for ACME (if using Let's Encrypt for internal domains)
    email augusto@cronova.dev

    # For internal-only services, use local/self-signed certs
    # Uncomment for production with real domains:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# =============================================================================
# INTERNAL SERVICES (Tailscale access)
# =============================================================================

# Vaultwarden - Password Manager
# Access: https://192.168.1.10:443 or via VPS proxy (vault.cronova.dev)
:8843 {
    reverse_proxy host.docker.internal:8843
}

# Home Assistant - Automation
# Access: https://home.cronova.dev (Tailscale) or http://192.168.1.10:8123
home.cronova.dev {
    reverse_proxy host.docker.internal:8123
}

# Jellyfin - Media Server
# Access: https://media.cronova.dev (Tailscale) or http://192.168.1.10:8096
media.cronova.dev {
    reverse_proxy host.docker.internal:8096
}

# Frigate - NVR
# Access: https://frigate.cronova.dev (Tailscale) or http://192.168.1.10:5000
frigate.cronova.dev {
    reverse_proxy host.docker.internal:5000

    # WebSocket support for live view
    @websockets {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websockets host.docker.internal:5000
}

# Pi-hole Admin - DNS Ad Blocking
# Access: http://192.168.1.10:80/admin (no HTTPS proxy needed)
# Pi-hole runs directly on port 80, not through Caddy

# =============================================================================
# ARR STACK (Optional HTTPS)
# =============================================================================
# These can be accessed directly via HTTP or proxied for HTTPS

# Sonarr
sonarr.cronova.dev {
    reverse_proxy host.docker.internal:8989
}

# Radarr
radarr.cronova.dev {
    reverse_proxy host.docker.internal:7878
}

# Prowlarr
prowlarr.cronova.dev {
    reverse_proxy host.docker.internal:9696
}

# =============================================================================
# SETUP NOTES
# =============================================================================
#
# 1. Tailscale MagicDNS:
#    Enable HTTPS certificates in Tailscale admin console:
#    https://login.tailscale.com/admin/dns
#    → Enable MagicDNS
#    → Enable HTTPS Certificates
#
# 2. DNS Configuration:
#    For *.cronova.dev subdomains to work internally:
#    - Add DNS records pointing to Tailscale IP (100.64.0.10)
#    - Or use Pi-hole local DNS to resolve internally
#
# 3. Alternative: Direct HTTP Access
#    Most services work fine over HTTP on local network:
#    - Home Assistant: http://192.168.1.10:8123
#    - Jellyfin: http://192.168.1.10:8096
#    - Frigate: http://192.168.1.10:5000
#
# 4. Docker Network:
#    Caddy uses host.docker.internal to reach services on Docker VM.
#    This requires: extra_hosts: ["host.docker.internal:host-gateway"]
#
# =============================================================================

# BentoPDF - PDF Tools (Kuatia)
# Access: https://kuatia.cronova.dev
# COOP/COEP headers required for Office conversion (SharedArrayBuffer/WASM)
kuatia.cronova.dev {
	import internal_tls
	import security_headers
	import authelia
	header Cross-Origin-Opener-Policy "same-origin"
	header Cross-Origin-Embedder-Policy "require-corp"
	reverse_proxy bentopdf:8080
}


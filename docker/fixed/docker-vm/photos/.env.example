# Immich Environment Variables
# Copy to .env and fill in values

# Timezone
TZ=America/Asuncion

# Upload location (NAS mount or named volume)
# Use a path for NAS-backed storage, or omit to use Docker named volume
UPLOAD_LOCATION=/mnt/nas/immich-upload

# Database credentials
DB_USERNAME=immich
DB_PASSWORD=<generate-secure-password>
DB_DATABASE_NAME=immich

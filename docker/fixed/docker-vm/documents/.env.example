# Paperless-ngx (Aranduka) Environment Variables
# Copy to .env and fill in values before deploying

TZ=America/Asuncion

# Admin credentials (created on first start)
PAPERLESS_ADMIN_USER=augusto
PAPERLESS_ADMIN_PASSWORD=<set-secure-password>

# Secret key for session tokens (generate: openssl rand -base64 32)
PAPERLESS_SECRET_KEY=<openssl-rand-base64-32>

# Database credentials (generate: openssl rand -base64 16)
PAPERLESS_DB_PASSWORD=<generate-secure-password>
PAPERLESS_DB_USER=paperless
PAPERLESS_DB_NAME=paperless

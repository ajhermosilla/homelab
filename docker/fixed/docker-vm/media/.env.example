# Media Stack Environment Variables
# Copy to .env and customize

# Timezone
TZ=America/Asuncion

# User/Group IDs (match host user for permissions)
PUID=1000
PGID=1000

# NAS mount paths (via NFS from 192.168.1.12)
MEDIA_PATH=/mnt/nas/media
DOWNLOADS_PATH=/mnt/nas/downloads

# VPN (optional - for qBittorrent)
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=your-private-key
# SERVER_COUNTRIES=Switzerland

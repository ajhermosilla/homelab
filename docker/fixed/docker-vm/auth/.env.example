# Auth Stack - Authelia (Oke)
# Copy to .env and configure

# Timezone
TZ=America/Asuncion

# Secrets are file-based (NOT env vars). Generate before first start:
#   mkdir -p config/secrets
#   openssl rand -base64 32 > config/secrets/jwt
#   openssl rand -base64 32 > config/secrets/session
#   openssl rand -base64 32 > config/secrets/encryption

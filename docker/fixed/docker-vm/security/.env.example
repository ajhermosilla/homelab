# Security Stack Environment Variables
# Copy to .env and customize
#
# NOTE: Sensitive values should use Docker secrets instead of env vars.
# See secrets/README.md for setup instructions.

# =============================================================================
# GENERAL
# =============================================================================

# Timezone
TZ=America/Asuncion

# Path to homelab repo (required for backup script mount)
# Default: /opt/homelab/repo
HOMELAB_ROOT=/home/augusto/homelab

# Vaultwarden admin token
# PREFERRED: Use Docker secrets (secrets/admin_token.txt)
# FALLBACK: Set here if not using secrets
# VAULTWARDEN_ADMIN_TOKEN=generate-a-secure-token-here

# Disable public signups after creating your account
VAULTWARDEN_SIGNUPS=false

# Frigate recordings path (NFS mount from NAS)
FRIGATE_RECORDINGS=/mnt/nas/frigate

# =============================================================================
# FRIGATE MQTT CREDENTIALS
# =============================================================================
# For Frigate → Mosquitto communication

FRIGATE_MQTT_USER=frigate
FRIGATE_MQTT_PASS=your-mqtt-password

# =============================================================================
# FRIGATE CAMERA CREDENTIALS
# =============================================================================
# These are substituted into frigate.yml RTSP URLs
# Set before starting Frigate!

# Reolink cameras (RLC-520A)
FRIGATE_REOLINK_USER=admin
FRIGATE_REOLINK_PASS=your-reolink-password

# TP-Link Tapo camera (C110)
# Create RTSP account in Tapo app: Camera Settings → Advanced → Device Account
FRIGATE_TAPO_USER=your-tapo-username
FRIGATE_TAPO_PASS=your-tapo-password

# =============================================================================
# BACKUP SIDECAR (Vaultwarden)
# =============================================================================

# Restic REST server credentials (NAS at 192.168.1.12:8000)
RESTIC_USER=augusto
RESTIC_PASS=your-htpasswd-password

# Restic encryption password
# PREFERRED: Use Docker secrets (secrets/restic_password.txt)
# FALLBACK: Set here if not using secrets
# RESTIC_PASSWORD=your-restic-encryption-password

# Optional: Override repository URL
# RESTIC_REPOSITORY=rest:http://augusto:pass@192.168.1.12:8000/vaultwarden

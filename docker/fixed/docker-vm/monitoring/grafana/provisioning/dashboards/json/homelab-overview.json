  "description": "Single pane of glass for the Cronova homelab",
  "editable": true,
  "id": null,
  "uid": "homelab-overview",
  "title": "Homelab Overview",
  "tags": ["homelab", "overview"],
  "style": "dark",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Host Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Docker VM — CPU",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{instance=\"docker-vm\", mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Docker VM — RAM",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
